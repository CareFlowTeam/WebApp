{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Backend: Flask (5000)",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"cd /d \"${workspaceFolder}\\backend\" && \"${workspaceFolder}\\.venv\\Scripts\\python.exe\" app.py"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Backend: Flask (5000) (pwsh)",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Set-Location -Path \"${workspaceFolder}\\backend\"; & \"${workspaceFolder}\\.venv\\Scripts\\python.exe\" app.py"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Backend: FastAPI (8000)",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Set-Location -Path \"${workspaceFolder}\"; & \"${workspaceFolder}\\.venv\\Scripts\\python.exe\" -m uvicorn backend.main:app --reload --port 8000"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Frontend: Vite Dev (5173)",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Set-Location -Path \"${workspaceFolder}\\frontend\"; npm run dev -- --host --port 5173"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Backend: FastAPI (8001)",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Set-Location -Path \"${workspaceFolder}\"; & \"${workspaceFolder}\\.venv\\Scripts\\python.exe\" -m uvicorn backend.main:app --reload --port 8001"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		}
	]
}